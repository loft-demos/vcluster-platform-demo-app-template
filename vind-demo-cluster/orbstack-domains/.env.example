# This file is only an example. The preferred path is to let
# vind-demo-cluster/start-orbstack-domains.sh generate .env automatically.
LOCAL_BASE_DOMAIN=vcp.local
VIND_DOCKER_NETWORK=vcluster.vcp
VCP_HOST=vcp.local
ARGOCD_HOST=argocd.vcp.local
FORGEJO_HOST=forgejo.vcp.local
